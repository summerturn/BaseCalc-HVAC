# BaseCalc HVAC environment variables
# Copy this file to .env and fill in real values.

# RevenueCat
EXPO_PUBLIC_REVENUECAT_IOS_API_KEY=your_ios_public_key
EXPO_PUBLIC_REVENUECAT_ANDROID_API_KEY=your_android_public_key

# Google AdMob
# Set EXPO_PUBLIC_ADMOB_USE_TEST_IDS=true only for local simulator/device testing.
EXPO_PUBLIC_ADMOB_USE_TEST_IDS=false
EXPO_PUBLIC_ADMOB_IOS_APP_ID=
EXPO_PUBLIC_ADMOB_ANDROID_APP_ID=
EXPO_PUBLIC_ADMOB_IOS_BANNER_UNIT_ID=
EXPO_PUBLIC_ADMOB_ANDROID_BANNER_UNIT_ID=
